{
  "name": "ally-ability",
  "version": "0.1.0",
  "private": true,
  "description": "The Ally-Ability Network — Inclusive learning platform for women, persons with disabilities, and teachers",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:web": "pnpm --filter @ally-ability/web dev",
    "dev:api": "pnpm --filter @ally-ability/api dev",
    "build": "pnpm -r run build",
    "build:web": "pnpm --filter @ally-ability/web build",
    "build:api": "pnpm --filter @ally-ability/api build",
    "lint": "pnpm -r run lint",
    "clean": "pnpm -r exec rm -rf node_modules dist .next .turbo"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
