# ===========================================
# The Ally-Ability Network — Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.

# Supabase (free tier — supabase.com)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudinary Video Storage (free tier - cloudinary.com)
CLOUDINARY_URL=cloudinary://my_key:my_secret@my_cloud_name

# Groq API (free tier — console.groq.com)
GROQ_API_KEY=

# Jitsi (public server — no key needed for MVP)
JITSI_SERVER_URL=https://meet.jit.si

# Brevo email (free tier — brevo.com)
BREVO_API_KEY=

# WhatsApp via Baileys (open source)
WHATSAPP_SESSION_FILE=./whatsapp-session.json

# App Configuration
NEXT_PUBLIC_API_URL=http://localhost:4000/v1
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
JWT_SECRET=your-jwt-secret-change-in-production
NODE_ENV=development
